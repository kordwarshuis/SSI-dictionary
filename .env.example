# Where individual per-glossary JSON files are written by the fetch scripts
GENERATED_JSON_GLOSSARIES_DIR=public/data/glossaries

# Where the combined dictionary.json is written by createDictionary.mjs
GENERATED_JSON_DICTIONARY_DIR=public/data

# Path to the GLOSSARY folder inside WOT-terms docs (used by fetchWotTermsContent)
# Point this at a local checkout of the WOT-terms repo if you want to include
# WebOfTrust definitions locally, otherwise that fetcher is skipped.
GLOSSARY_DIR=glossary
